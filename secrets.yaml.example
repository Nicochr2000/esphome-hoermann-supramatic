# Copy this file to secrets.yaml and fill in your own values.
# secrets.yaml is git-ignored so your credentials never end up on GitHub.

wifi_ssid: "YourWifiSSID"
wifi_password: "YourWifiPassword"

# Home Assistant API encryption key (32-byte base64).
# Generate one at: https://esphome.io/components/api.html  (or `openssl rand -base64 32`)
garagedoor_api_encryption_key: "REPLACE_WITH_BASE64_KEY"

# OTA update password
garagedoor_ota_password: "REPLACE_WITH_OTA_PASSWORD"

# Fallback access-point password (used if Wi-Fi is unavailable)
garagedoor_ap_password: "REPLACE_WITH_AP_PASSWORD"
